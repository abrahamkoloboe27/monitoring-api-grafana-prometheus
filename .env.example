# Copy this file to .env and fill in the values before running docker compose up.
# The .env file is git-ignored so credentials won't be committed.

# ── Grafana admin credentials ────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# ── SMTP (email alerts) ──────────────────────────────────────────────────────
# Set GF_SMTP_ENABLED=true to activate email notifications.
GF_SMTP_ENABLED=false
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your-email@gmail.com
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords)
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM_ADDRESS=your-email@gmail.com
GF_SMTP_FROM_NAME=Grafana Monitoring
GF_SMTP_STARTTLS_POLICY=MandatoryStartTLS

# ── Alert recipients ─────────────────────────────────────────────────────────
# Semicolon-separated list of email addresses that will receive alert notifications.
ALERT_EMAIL_TO=team@example.com

# ── Google Chat (optional) ───────────────────────────────────────────────────
# Create a Google Chat incoming webhook in your Space settings:
#   Space → Apps & integrations → Manage webhooks → Add webhook
# Then paste the URL below.
GOOGLECHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=KEY&token=TOKEN
