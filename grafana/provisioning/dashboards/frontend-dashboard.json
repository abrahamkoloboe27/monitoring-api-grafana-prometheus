{
  "id": null,
  "uid": "frontend-monitoring",
  "title": "Frontend Monitoring (React & Vue)",
  "tags": ["frontend", "nodejs", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "React – Total Requests (last 5 min)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(frontend_http_requests_total{app=\"react\"}[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Vue – Total Requests (last 5 min)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(frontend_http_requests_total{app=\"vue\"}[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "React – Node.js Heap Used",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{app=\"react\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000000 },
              { "color": "red", "value": 100000000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Vue – Node.js Heap Used",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{app=\"vue\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50000000 },
              { "color": "red", "value": 100000000 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Frontend App",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (app) (rate(frontend_http_requests_total[1m]))",
          "legendFormat": "{{app}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate by Route (React)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(frontend_http_requests_total{app=\"react\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate by Route (Vue)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (route) (rate(frontend_http_requests_total{app=\"vue\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Response Latency p50/p90/p99 (React)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(frontend_http_request_duration_seconds_bucket{app=\"react\"}[1m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(frontend_http_request_duration_seconds_bucket{app=\"react\"}[1m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(frontend_http_request_duration_seconds_bucket{app=\"react\"}[1m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Node.js Event Loop Lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{app=\"react\"}",
          "legendFormat": "React event loop lag"
        },
        {
          "expr": "nodejs_eventloop_lag_seconds{app=\"vue\"}",
          "legendFormat": "Vue event loop lag"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Node.js CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{app=\"react\"}[1m])",
          "legendFormat": "React CPU"
        },
        {
          "expr": "rate(process_cpu_seconds_total{app=\"vue\"}[1m])",
          "legendFormat": "Vue CPU"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Error Rate (4xx + 5xx) – Frontends",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum by (app) (rate(frontend_http_requests_total{status_code=~\"4..\"}[1m]))",
          "legendFormat": "{{app}} 4xx"
        },
        {
          "expr": "sum by (app) (rate(frontend_http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "{{app}} 5xx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
