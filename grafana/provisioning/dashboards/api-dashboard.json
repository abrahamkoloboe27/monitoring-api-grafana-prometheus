{
  "id": null,
  "uid": "fastapi-monitoring",
  "title": "FastAPI Monitoring",
  "tags": ["fastapi", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (last 5 min)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (last 5 min)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx Errors"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Response Time (ms)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "avg(rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])) * 1000",
          "legendFormat": "Avg Latency"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 500 }] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Requests",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress)",
          "legendFormat": "In Progress"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }] } }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (handler) (rate(http_requests_total[1m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Response Latency Percentiles (p50 / p90 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "4xx / 5xx Error Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 9,
      "type": "row",
      "title": "Request Origins – qui appelle l'API ?",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Rate by Source",
      "description": "Shows which client or frontend is calling the API, identified from the Referer / Origin header. 'direct' means no Referer header was sent (curl, Postman, server-to-server, etc.).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "sum by (source) (rate(api_requests_by_source_total[1m]))",
          "legendFormat": "{{source}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate by Client Type",
      "description": "Broad category of the caller derived from the User-Agent header: browser, node (server-side proxy), python (scripts / load tests), curl, other, unknown.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "sum by (client_type) (rate(api_requests_by_source_total[1m]))",
          "legendFormat": "{{client_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Response Status by Source",
      "description": "HTTP status codes grouped by caller origin. Helps detect which client is generating errors.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "targets": [
        {
          "expr": "sum by (source, status_code) (rate(api_requests_by_source_total[1m]))",
          "legendFormat": "{{source}} – {{status_code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Request Summary by Source × Route (last 5 min)",
      "description": "Tabular breakdown: which source called which endpoint, how many times, and what response codes it received.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "targets": [
        {
          "expr": "sort_desc(sum by (source, client_type, handler, status_code) (increase(api_requests_by_source_total[5m])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Requests" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status_code" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 400  },
                    { "color": "red",    "value": 500  }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "labelsToFields",  "options": { "mode": "columns" } },
        { "id": "sortBy", "options": { "fields": [{ "displayName": "Value", "desc": true }] } }
      ]
    },
    {
      "id": 14,
      "type": "piechart",
      "title": "Source Distribution (last 5 min)",
      "description": "Proportion of requests per source over the last 5 minutes.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "targets": [
        {
          "expr": "sum by (source) (increase(api_requests_by_source_total[5m]))",
          "legendFormat": "{{source}}",
          "instant": true
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 15,
      "type": "piechart",
      "title": "Client Type Distribution (last 5 min)",
      "description": "Proportion of requests per client type over the last 5 minutes.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "targets": [
        {
          "expr": "sum by (client_type) (increase(api_requests_by_source_total[5m]))",
          "legendFormat": "{{client_type}}",
          "instant": true
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
